# Copy these values into your hosting platform's production environment settings.
# Do not commit real production secrets.

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/stocksense?schema=public

# App URLs
APP_URL=https://your-production-domain.com
NEXTAUTH_URL=https://your-production-domain.com

# Generate a long random value for production only.
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Stripe live mode
STRIPE_SECRET_KEY=sk_live_replace_with_live_secret_key
STRIPE_PRICE_ID=price_replace_with_live_recurring_price_id
STRIPE_WEBHOOK_SECRET=whsec_replace_with_live_webhook_signing_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_replace_with_live_publishable_key

# Email / SMTP
EMAIL_FROM=hello@your-production-domain.com
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Optional notification providers
SMS_PROVIDER_PLACEHOLDER=
WHATSAPP_PROVIDER_PLACEHOLDER=
